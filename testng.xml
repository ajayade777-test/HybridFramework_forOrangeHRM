<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OrangeHRM_Suite" parallel="tests" thread-count="2">

	<listeners>
		<listener class-name="com.orangehrm.utilities.ExtentListener" />
	</listeners>

	<!-- Run tests in Chrome -->
	<test name="ChromeTests">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.orangehrm.tests.LoginTest" />
			<class name="com.orangehrm.tests.RequirementTest" />
		</classes>
	</test>

	<!-- Run tests in Edge -->
	<test name="EdgeTests">
		<parameter name="browser" value="edge" />
		<classes>
			<class name="com.orangehrm.tests.LoginTest" />
			<class name="com.orangehrm.tests.RequirementTest" />
		</classes>
	</test>

</suite>
